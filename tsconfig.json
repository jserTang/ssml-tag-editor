{
    "compilerOptions": {
      "alwaysStrict": true,
      "jsx": "react",
      "target": "es5",
      "module": "commonjs",
      "lib": ["dom", "es2015"],
      "noEmitHelpers": true,
      "importHelpers": true,
      "declaration": true,
      "declarationDir": "dist",
      "typeRoots": ["./node_modules/@types", "./types"],
      "moduleResolution": "node",
      "baseUrl": "src/",
      "esModuleInterop": true,
      "paths": {
        "*": ["*", "src/*"]
      },
    }
  }